# LLM Provider
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
LLM_MODEL=nousresearch/hermes-3-llama-3.1-405b

# Emblem Vault
EMBLEM_API_KEY=
EMBLEM_WALLET_PASSWORD=
EMBLEM_DEFAULT_CHAIN=solana

# Gateway
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# Memory
MEMORY_DB_PATH=./memory_store/emblem_ai.db
MEMORY_SEARCH_LIMIT=10

# Scheduling
PORTFOLIO_CHECK_CRON=0 */4 * * *
NEWS_DIGEST_CRON=0 8 * * *
